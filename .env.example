# .env.example - Vertex AI版
# 実際の .env はgit追跡外です（.gitignore 済み）

# ============================================================
# [必須] Google Cloud プロジェクト設定
# ============================================================
GCP_PROJECT_ID=your-project-id-here
GCP_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash

# ============================================================
# [認証] どちらかを設定
# ============================================================
# A) ローカル開発: `gcloud auth application-default login` 実行後、この変数は不要
#    gcloud が ~/.config/gcloud/application_default_credentials.json に保存する
#
# B) 本番(Render)等: サービスアカウントJSON全文を環境変数に貼る
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...",...}

# ============================================================
# [推奨] アクセス制御・監査
# ============================================================
# ACCESS_PASSWORD=change-me
# ADMIN_TOKEN=random-long-string

# ============================================================
# [任意] レート制限 (Vertex AIの高RPM枠に合わせ緩め)
# ============================================================
RATE_LIMIT_PER_MIN=300
RATE_LIMIT_PER_DAY=5000
GLOBAL_DAILY_CAP=20000
# PORT=10000
