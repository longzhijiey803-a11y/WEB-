# .env.example - ローカル開発用のテンプレート
# 実際の .env は git にコミットされません（.gitignore 済み）
# Render 本番環境では Render ダッシュボードで同じ環境変数を設定してください

# [必須] Gemini APIキー
GEMINI_API_KEY=your-gemini-api-key-here

# [任意] 使用するモデル
GEMINI_MODEL=gemini-2.5-flash-lite

# [推奨] アクセスパスワード - 設定すると閲覧者にパスワード必須になる
# ACCESS_PASSWORD=change-me

# [推奨] 監査ログ閲覧用の管理トークン
# 設定すると /admin/logs?token=xxx /admin/summary?token=xxx が有効
# ADMIN_TOKEN=random-long-string

# [任意] レート制限 (デフォルト値)
RATE_LIMIT_PER_MIN=60
RATE_LIMIT_PER_DAY=500
GLOBAL_DAILY_CAP=5000

# [任意] ポート (Render では自動設定される)
# PORT=10000
